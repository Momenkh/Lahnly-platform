# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/lahnly"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Tokens granted per Stripe price ID on invoice.paid
# Format: STRIPE_TOKENS_<PRICE_ID_UPPERCASE>=<tokens>
# e.g. STRIPE_TOKENS_PRICE_ABC123=100

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lahnly
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Core processor
CORE_PROCESSOR_PATH=/app/core-processor
PYTHON_BIN=python

# App
PORT=3000
NODE_ENV=development

# Dev only — skip Clerk JWT validation, use x-dev-user-id header instead
# NEVER set this to true in production
DEV_BYPASS=false
