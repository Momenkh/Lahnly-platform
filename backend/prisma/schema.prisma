generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())

  tokenBalance TokenBalance?
  transactions TokenTransaction[]
  songs        Song[]
  publications Publication[]
}

model TokenBalance {
  userId  String @id
  balance Int    @default(0)
  user    User   @relation(fields: [userId], references: [id])
}

model TokenTransaction {
  id          String            @id @default(cuid())
  userId      String
  delta       Int
  reason      TransactionReason
  referenceId String?
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum TransactionReason {
  SUBSCRIPTION_GRANT
  JOB_DEDUCT
  JOB_REFUND
}

model Song {
  id               String   @id @default(cuid())
  userId           String
  title            String
  originalFilename String
  audioStorageKey  String
  durationSeconds  Float
  createdAt        DateTime @default(now())

  user        User            @relation(fields: [userId], references: [id])
  jobs        ProcessingJob[]
  publication Publication?
}

model ProcessingJob {
  id             String    @id @default(cuid())
  songId         String
  userId         String
  instruments    String[]
  status         JobStatus @default(QUEUED)
  tokensDeducted Int
  queueJobId     String?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  song    Song        @relation(fields: [songId], references: [id])
  results JobResult[]
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model JobResult {
  id                String   @id @default(cuid())
  jobId             String
  instrument        String
  notesStorageKey   String
  previewStorageKey String
  evalScore         Float?
  createdAt         DateTime @default(now())

  job       ProcessingJob  @relation(fields: [jobId], references: [id])
  revisions NoteRevision[]
}

model NoteRevision {
  id        String   @id @default(cuid())
  resultId  String
  notes     Json
  createdAt DateTime @default(now())

  result JobResult @relation(fields: [resultId], references: [id])
}

model Publication {
  id          String   @id @default(cuid())
  songId      String   @unique
  userId      String
  title       String
  description String?
  instruments String[]
  isPublic    Boolean  @default(true)
  publishedAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
